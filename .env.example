# Strava API Credentials
# Get these from https://www.strava.com/settings/apps
VITE_STRAVA_CLIENT_ID=your_client_id_here
VITE_STRAVA_CLIENT_SECRET=your_client_secret_here

# Redirect URI for OAuth callback
# Use http://localhost:5173/callback for local development
# Use https://cgt.mockletdesign.com/callback for production
VITE_STRAVA_REDIRECT_URI=http://localhost:5173/callback

# Supabase
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
